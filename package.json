{
	"name": "handoff-plugin",
	"version": "0.1.0",
	"private": true,
	"description": "Automatically write handoff.md and index.jsonl on Cline compact events",
	"type": "module",
	"scripts": {
		"typecheck": "tsc --noEmit"
	},
	"exports": {
		".": "./src/index.mjs"
	},
	"cline": {
		"plugins": [
			{
				"paths": [
					"./src/index.mjs"
				],
				"capabilities": [
					"messageBuilders"
				]
			}
		]
	},
	"peerDependencies": {
		"@cline/core": "*",
		"@cline/shared": "*"
	},
	"peerDependenciesMeta": {
		"@cline/core": {
			"optional": true
		},
		"@cline/shared": {
			"optional": true
		}
	}
}
