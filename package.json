{
	"name": "context-snapshot",
	"version": "0.5.0",
	"private": true,
	"description": "Context snapshot plugin: compact observer + rules injection + tool-call recorder + loop guard (beforeModel)",
	"type": "module",
	"scripts": {
		"typecheck": "tsc --noEmit"
	},
	"exports": {
		".": "./src/index.ts"
	},
	"cline": {
		"plugins": [
			{
				"paths": [
					"./src/index.ts"
				],
				"capabilities": [
					"messageBuilders",
					"rules",
					"hooks"
				]
			}
		]
	},
	"peerDependencies": {
		"@cline/core": "*",
		"@cline/shared": "*"
	},
	"peerDependenciesMeta": {
		"@cline/core": {
			"optional": true
		},
		"@cline/shared": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/node": "^26.0.1",
		"typescript": "^6.0.3"
	}
}
